<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorPrimary" />
        </shape>
    </item>

    <item android:top="-40dp" android:left="-50dp" android:width="120dp" android:height="120dp">
        <shape android:shape="oval">
            <stroke android:width="8dp" android:color="#4CAF50" />
            <solid android:color="#1A4CAF50" />
        </shape>
    </item>

    <item android:gravity="end|top" android:top="-20dp" android:right="-30dp" android:width="80dp" android:height="80dp">
        <shape android:shape="rectangle">
            <stroke android:width="8dp" android:color="#2196F3" />
            <solid android:color="#1A2196F3" />
        </shape>
    </item>

    <item android:gravity="center_horizontal" android:width="100dp" android:height="16dp" android:top="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#33FFEB3B" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <item
        android:drawable="@drawable/ic_bug"
        android:gravity="start|top"
        android:left="60dp"
        android:top="5dp"
        android:width="20dp"
        android:height="20dp"
        android:alpha="0.2" />

    <item
        android:drawable="@drawable/ic_bug"
        android:gravity="center"
        android:left="-40dp"
        android:top="-10dp"
        android:width="24dp"
        android:height="24dp"
        android:alpha="0.3" />

    <item
        android:drawable="@drawable/ic_bug"
        android:gravity="end|top"
        android:right="80dp"
        android:top="8dp"
        android:width="22dp"
        android:height="22dp"
        android:alpha="0.15" />

    <item
        android:drawable="@drawable/ic_bug"
        android:gravity="center_horizontal|bottom"
        android:bottom="2dp"
        android:width="18dp"
        android:height="18dp"
        android:alpha="0.25" />

</layer-list>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintWidth_max="@dimen/max_content_width"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvGeneratedCodeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/generated_code"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"/>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sharing_code"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="@dimen/title_margin_bottom"
                android:textAlignment="center"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCodeContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="40dp"
                app:cardBackgroundColor="@android:color/white">

                <ImageView
                    android:id="@+id/imageViewGeneratedCode"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:scaleType="fitCenter"
                    android:padding="32dp"
                    android:contentDescription="@string/code_image"
                    tools:src="@drawable/baseline_qr_code_24"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonShare"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/share"
                    android:textSize="16sp"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_share"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    style="@style/Widget.Material3.Button"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSave"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/save"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_save"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saved_code"
                android:textSize="12sp"
                android:textColor="?attr/colorOutline"
                android:layout_marginTop="24dp"
                android:textAlignment="center"/>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
